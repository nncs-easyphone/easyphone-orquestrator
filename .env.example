# ==============================
# Orquestrator - Environment Variables
# ==============================
# Copiado automaticamente pelo init.sh na primeira execução.
# Valores marcados com ⚠  são críticos de segurança — altere para senhas fortes.

# ---------- Global ----------
DOMAIN=exemplo.com
LETSENCRYPT_EMAIL=admin@exemplo.com
# USE_BUILD=true  → build local (./run.sh)
# USE_BUILD=false → pull das imagens do registry (./run.sh)
USE_BUILD=false

# ---------- Postgres ----------
POSTGRES_USER=easyfone
# ⚠ Altere a senha abaixo
POSTGRES_PASSWORD=easyfone
POSTGRES_DB=easyfone

# ---------- API ----------
NODE_ENV=production
# ⚠ Altere o JWT_SECRET e DATA_SECRET_CRYPTOGRAPHY_KEY
JWT_SECRET=easyfone-jwt-secret
DATA_SECRET_CRYPTOGRAPHY_KEY=easyfone-crypto-key-32bytes!
MAX_CAPTURE_GROUPS=64
EASYPHONE_FIREBASE_URL=https://services.easyphone.com.br
ACTIVATE_DISCADOR_MAILING=false
EF_AMI_DIALPLAN_EXTENSION_CONTEXT=CAT_FULL
EF_DIALPLAN_EXTENSION_CONTEXT_BLOCK=CAT_BLOCK

# ---------- Firebase ----------
# ⚠ Substitua pelo JSON real da sua conta de serviço (em linha única)
EASYPHONE_FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"123","private_key_id":"123","private_key":"123","client_email":"123","client_id":"123","auth_uri":"123","token_uri":"123","auth_provider_x509_cert_url":"123","client_x509_cert_url":"123","universe_domain":"123"}

# ---------- Paths (montagens de volume) ----------
MUSIC_ON_HOLD_FOLDER_PATH=/var/lib/asterisk/moh
AUDIO_URA_FOLDER_PATH=/var/lib/asterisk/sounds/ura
VITE_EF_FILES_FOLDER_PATH=/etc/asterisk
VITE_EF_CALL_RECORD_FOLDER_PATH=/var/spool/asterisk/monitor

# ---------- Web ----------
VITE_FORMAT_FILES_UPLOAD_MOH=mp3
VITE_MAX_FILES_UPLOAD_MOH=5
VITE_MAX_FILE_SIZE_UPLOAD_MOH=8097152
VITE_MAX_FILE_SIZE_UPLOAD_IVR_AUDIO=2097152

# ---------- Asterisk ----------
ASTERISK_DB_NAME=easyfone
ASTERISK_DB_USER=easyfone
# ⚠ Altere a senha abaixo
ASTERISK_DB_PASS=easyfone
VITE_ASTERISK_USERNAME=easyphone
# ⚠ Altere a senha abaixo
VITE_ASTERISK_PASSWORD=test123

# ---------- Transcriber ----------
WHISPER_MODEL=large           # Opções: tiny, base, small, medium, large

# ---------- License ----------
# Client ID da licença no Firebase (opcional — se vazio, status retorna 'blocked')
EASYPHONE_LICENSE_CLIENT_ID=default-testing-client-id
EASYPHONE_LICENSE_HARDWARE_ID=
