# ==============================
# Orquestrator - Environment Variables
# ==============================
# Copy this file to .env and adjust the values.
# docker-compose reads .env automatically.

# ---------- Global ----------
COMPOSE_PROJECT_NAME=easyfone
TZ=UTC
# USE_BUILD=true  → build local dos Dockerfiles (./run.sh)
# USE_BUILD=false → imagens do registry com pull (./run.sh)
USE_BUILD=false

# ---------- Postgres ----------
POSTGRES_IMAGE_TAG=17-alpine
PG_PORT_HOST=7001
POSTGRES_USER=easyfone
POSTGRES_PASSWORD=easyfone
POSTGRES_DB=easyfone

# ---------- API ----------
API_IMAGE=ghcr.io/nncs-easyphone/easyphone-api:main
API_PORT_HOST=7002
API_PORT_CONTAINER=7002

NODE_ENV=production
JWT_SECRET=easyfone-jwt-secret
CORS_ORIGIN=http://localhost:7000
PGBOUNCER_PORT_HOST=7003

MAX_CAPTURE_GROUPS=64
VITE_MAX_FILE_SIZE_UPLOAD_MOH=2097152

MUSIC_ON_HOLD_FOLDER_PATH=/var/lib/asterisk/moh
VITE_EF_FILES_FOLDER_PATH=/etc/asterisk/dialplan
AUDIO_URA_FOLDER_PATH=/var/lib/asterisk/sounds/ura
VITE_EF_CALL_RECORD_FOLDER_PATH=/var/spool/asterisk/monitor

# Asterisk roda em host networking → api/seed o alcançam pelo gateway do host.
VITE_ASTERISK_HOST=host.docker.internal
VITE_ASTERISK_ARI_PORT=8088
VITE_ASTERISK_AMI_PORT=5038
VITE_ASTERISK_USERNAME=easyphone
VITE_ASTERISK_PASSWORD=test123
VITE_TIMEOUT_ORIGINATE_LOGIN_CALL_MS=15000
VITE_APP_NAME_ARI_ASTERISK=easyphone

PRISMA_LOGS_OFF=true
PG_POOL_MAX=20
PG_POOL_MIN=10
DATA_SECRET_CRYPTOGRAPHY_KEY=easyfone-crypto-key-32bytes!
AI_AUDIO_GENERATION_ENDPOINT=http://placeholder:8080
ACTIVATE_DISCADOR_MAILING=false
EF_AMI_DIALPLAN_EXTENSION_CONTEXT=CAT_FULL
EF_DIALPLAN_EXTENSION_CONTEXT_BLOCK=CAT_BLOCK

FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"123","private_key_id":"123","private_key":"123","client_email":"123","client_id":"123","auth_uri":"123","token_uri":"123","auth_provider_x509_cert_url":"123","client_x509_cert_url":"123","universe_domain":"123"}

# ---------- Web ----------
WEB_IMAGE=ghcr.io/nncs-easyphone/easyphone-web:main
WEB_PORT_CONTAINER=7000
WEB_PORT_HOST=7000
VITE_API_URL=http://localhost:7002
VITE_API_DELAY=0
VITE_ENABLE_API_DELAY=false
VITE_FORMAT_FILES_UPLOAD_MOH=mp3
VITE_MAX_FILES_UPLOAD_MOH=5
VITE_MAX_FILE_SIZE_UPLOAD_MOH=8097152
VITE_MAX_FILE_SIZE_UPLOAD_IVR_AUDIO=2097152

# ---------- Asterisk ----------
ASTERISK_IMAGE=ghcr.io/nncs-easyphone/easyphone-asterisk:main
# Asterisk roda em host networking: o banco é alcançado em 127.0.0.1:${PG_PORT_HOST}
# (Postgres publicado no host). DB_HOST/DB_PORT são fixados no compose; aqui ficam
# apenas nome/usuário/senha do banco.
ASTERISK_DB_NAME=easyfone
ASTERISK_DB_USER=easyfone
ASTERISK_DB_PASS=easyfone
