# Coturn — STUN/TURN/TURNS para WebRTC
# GERADO AUTOMATICAMENTE pelo init.sh. Não editar manualmente.

# ── Rede ──────────────────────────────────────────────────────────────
listening-port=3478
tls-listening-port=5349
listening-ip=0.0.0.0
# IP público anunciado nos candidatos. Se COTURN_EXTERNAL_IP estiver vazio no
# .env, o init.sh remove esta linha e vale a autodetecção do CMD da imagem
# (--external-ip=$(detect-external-ip)).
external-ip=${COTURN_EXTERNAL_IP}

# ── Identidade ────────────────────────────────────────────────────────
realm=pbx.${DOMAIN}
server-name=pbx.${DOMAIN}

# ── Autenticação (long-term credentials) ──────────────────────────────
lt-cred-mech
user=${COTURN_USER}:${COTURN_PASS}

# ── Portas de relay RTP ───────────────────────────────────────────────
min-port=49152
max-port=65535

# ── TLS ───────────────────────────────────────────────────────────────
# Certificado Let's Encrypt de pbx.${DOMAIN}, extraído do acme.json do Traefik
# pelo serviço certs-dumper.
# Enquanto o certificado não existir, o Coturn NÃO aborta: loga
# "cannot start TLS and DTLS listeners" e segue servindo STUN e TURN na 3478.
# O TURNS (5349) só entra depois que o certificado aparecer — e como o Coturn
# lê o certificado apenas no arranque, é preciso um
# `docker compose restart coturn` após a primeira emissão (e a cada renovação).
cert=/certs/pbx.${DOMAIN}/certificate.pem
pkey=/certs/pbx.${DOMAIN}/privatekey.pem
cipher-list="HIGH"

# ── Segurança ─────────────────────────────────────────────────────────
fingerprint
no-multicast-peers
no-cli

# Bloqueia relay para faixas privadas (previne SSRF via TURN).
# ATENÇÃO: se a VM tiver IP privado (NAT 1:1), remova a faixa correspondente —
# do contrário o relay para o próprio Asterisk é negado.
denied-peer-ip=0.0.0.0-0.255.255.255
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=100.64.0.0-100.127.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=240.0.0.0-255.255.255.255

# ── Log ───────────────────────────────────────────────────────────────
log-file=stdout
new-log-timestamp
